# Environment variables / Secrets
.env
.env.*
*.key
*.pem
credentials.json
credentials*.json
secrets/

# Audit logs (generated at runtime, not committed)
audit/logs/

# Python
__pycache__/
*.pyc
.pytest_cache/
*.egg-info/
dist/
build/
*.egg

# Node.js
node_modules/
.next/

# macOS
.DS_Store
Thumbs.db

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~
output/

# Claude Code local state (in the engine repo root only)
/.claude/

# Transient session files
.chat-force-swarm-prompt.md
.ticket-context
# But allow .claude/ inside templates (they're tracked content)
!templates/**/.claude/
