{
  "agents": {
    "defaults": {
      "workspace": "~/.openclaw/workspace",
      "model": {
        "primary": "anthropic/claude-opus-4-6"
      }
    }
  },

  "channels": {
    "slack": {
      "enabled": true,
      "botToken": "${SLACK_BOT_TOKEN}",
      "appToken": "${SLACK_APP_TOKEN}",
      "dmPolicy": "open",
      "groupPolicy": "open",
      "historyLimit": 50
    }
  },

  "gateway": {
    "port": 3001,
    "mode": "local",
    "bind": "lan",
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    }
  },

  "browser": {
    "enabled": true,
    "headless": true,
    "noSandbox": true
  },

  "tools": {
    "profile": "full",
    "exec": {
      "security": "full"
    }
  },

  "logging": {
    "level": "info"
  }
}
