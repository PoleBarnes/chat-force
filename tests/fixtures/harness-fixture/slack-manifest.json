{
  "_metadata": {
    "major_version": 1,
    "minor_version": 1
  },
  "display_information": {
    "name": "TestBot",
    "description": "Test fixture bot used by the chat-force test suite.",
    "background_color": "#202020",
    "long_description": "TestBot is a minimal fixture harness used by the chat-force engine tests. It exists solely to satisfy HarnessLoader validation; it is not a real deployed bot and should never be installed in any real Slack workspace."
  },
  "features": {
    "bot_user": {
      "display_name": "TestBot",
      "always_online": false
    }
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "assistant:write",
        "app_mentions:read",
        "channels:history",
        "channels:join",
        "chat:write",
        "files:read",
        "files:write",
        "groups:history",
        "groups:read",
        "im:history",
        "im:read",
        "im:write",
        "reactions:read",
        "reactions:write",
        "users:read"
      ]
    },
    "pkce_enabled": false
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "app_mention",
        "assistant_thread_context_changed",
        "assistant_thread_started",
        "message.channels",
        "message.groups",
        "message.im"
      ]
    },
    "interactivity": {
      "is_enabled": true
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}
