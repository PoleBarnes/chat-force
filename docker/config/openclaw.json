{
  "agents": {
    "defaults": {
      "workspace": "~/.openclaw/workspace",
      "model": {
        "primary": "anthropic/claude-opus-4-6"
      }
    }
  },

  "channels": {
    "slack": {
      "enabled": true,
      "botToken": "${SLACK_BOT_TOKEN}",
      "appToken": "${SLACK_APP_TOKEN}",
      "dmPolicy": "open",
      "allowFrom": ["*"],
      "groupPolicy": "open",
      "historyLimit": 50
    }
  },

  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "lan",
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    }
  },

  "models": {
    "providers": {
      "gemini": {
        "api": "google-generative-ai",
        "apiKey": "${GEMINI_API_KEY}",
        "baseUrl": "https://generativelanguage.googleapis.com/v1beta",
        "models": [
          {
            "id": "gemini-2.5-pro",
            "name": "Gemini 2.5 Pro",
            "contextWindow": 1048576,
            "input": ["text", "image"]
          },
          {
            "id": "gemini-2.5-flash",
            "name": "Gemini 2.5 Flash",
            "contextWindow": 1048576,
            "input": ["text", "image"]
          }
        ]
      }
    }
  },

  "browser": {
    "enabled": true,
    "headless": true,
    "noSandbox": true
  },

  "tools": {
    "profile": "full",
    "exec": {
      "security": "full"
    }
  },

  "logging": {
    "level": "info"
  }
}
