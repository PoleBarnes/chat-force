{
  "name": "research-spike",
  "description": "Research task \u2014 output is vault entries and a summary",
  "required_inputs": [
    {
      "name": "title",
      "type": "string",
      "description": "Short ticket title"
    },
    {
      "name": "question",
      "type": "string",
      "description": "The research question to answer"
    },
    {
      "name": "scope",
      "type": "string",
      "description": "Boundaries of the research"
    }
  ],
  "required_artifacts": [
    "vault/summaries/sources/*.md",
    "vault/summaries/sessions/*.md"
  ],
  "acceptance_criteria": [
    "Research question is answered with cited sources",
    "At least one vault summary written",
    "No hallucinated facts or URLs",
    "Scope boundaries respected"
  ],
  "skills": [
    "vault-ingest"
  ]
}
