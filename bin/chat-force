#!/usr/bin/env bash
#
# chat-force — self-improving prototyping tool
#
# Chains two Claude Code CLI sessions:
#   1. Prototype: full-power prototyping
#   2. Mechanic: analyzes the session, proposes improvements
#
set -euo pipefail

CHAT_FORCE_VERSION="0.1.0"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
TEMPLATES_DIR="$SCRIPT_DIR/templates"
MECHANIC_PROMPT="$TEMPLATES_DIR/mechanic-prompt.md"
PM_PROMPT="$TEMPLATES_DIR/pm-prompt.md"

BLUE='\033[0;34m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

info()  { echo -e "${BLUE}[chat-force]${NC} $*"; }
ok()    { echo -e "${GREEN}[chat-force]${NC} $*"; }
warn()  { echo -e "${YELLOW}[chat-force]${NC} $*"; }
error() { echo -e "${RED}[chat-force]${NC} $*" >&2; }

require_claude() {
    command -v claude &>/dev/null || { error "Claude Code CLI not found."; exit 1; }
}

require_project() {
    [[ -f "CLAUDE.md" ]] || { error "Not a chat-force project. Run 'chat-force init' first."; exit 1; }
}

# ---------------------------------------------------------------------------
cmd_prototype() {
    require_claude
    require_project

    # Generate a session ID so we can hand it to the mechanic.
    # Claude Code CLI accepts --session-id to tag the session.
    local session_id
    session_id=$(uuidgen 2>/dev/null || python3 -c "import uuid; print(uuid.uuid4())")

    info "Starting prototyping session: $session_id"
    info "Type /exit or Ctrl+C when done."
    echo ""

    # Run Claude Code CLI with our session ID — pass all extra args through
    local exit_code=0
    claude --session-id "$session_id" "$@" || exit_code=$?

    echo ""
    [[ $exit_code -ne 0 ]] && [[ $exit_code -ne 130 ]] && warn "Session exited with code $exit_code"

    info "Prototype session complete: $session_id"
    local response
    read -r -p "$(echo -e "${BLUE}[chat-force]${NC} Launch mechanic review? [Y/n] ")" response
    response=${response:-Y}

    if [[ "$response" =~ ^[Yy]$ ]]; then
        echo ""
        cmd_mechanic "$session_id"
    else
        info "Skipping mechanic. Run 'chat-force mechanic' later."
    fi
}

# ---------------------------------------------------------------------------
cmd_mechanic() {
    require_claude
    require_project

    local session_id="${1:-}"

    info "🔧 Launching mechanic review..."
    [[ -n "$session_id" ]] && info "Session: $session_id"
    echo ""

    local mechanic_args=()
    if [[ -f "$MECHANIC_PROMPT" ]]; then
        mechanic_args+=(--system-prompt "$MECHANIC_PROMPT")
    fi

    # Build context about which session to analyze
    local session_context=""
    if [[ -n "$session_id" ]]; then
        # Try to find the session transcript
        local project_path
        project_path="$(pwd)"
        local project_key="${project_path//\//-}"
        local session_file="$HOME/.claude/projects/-${project_key}/${session_id}.jsonl"

        if [[ -f "$session_file" ]]; then
            session_context="Session transcript is at: $session_file"
            info "Found session transcript."
        else
            session_context="Session ID is $session_id but transcript file not found. Analyze from git state instead."
            info "Session file not found — mechanic will work from git state."
        fi
    fi

    # The mechanic runs interactively by default.
    # If extra args include -p, it runs non-interactively (for testing).
    local remaining_args=("${@:2}")
    claude "${mechanic_args[@]}" "${remaining_args[@]}"
}

# ---------------------------------------------------------------------------
cmd_init() {
    local template="general"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --template) template="$2"; shift 2 ;;
            *) shift ;;
        esac
    done

    local tpl="$TEMPLATES_DIR/$template"
    [[ -d "$tpl" ]] || { error "Template '$template' not found."; exit 1; }

    info "Initializing project (template: $template)..."

    [[ ! -f "CLAUDE.md" ]] && cp "$tpl/CLAUDE.md" ./CLAUDE.md && ok "  Created CLAUDE.md"
    [[ -f "$tpl/.mcp.json" ]] && [[ ! -f ".mcp.json" ]] && \
        cp "$tpl/.mcp.json" ./.mcp.json && ok "  Created .mcp.json (MCP server config)"

    mkdir -p .claude/rules .claude/skills .claude/agents
    [[ -f "$tpl/.claude/settings.json" ]] && [[ ! -f ".claude/settings.json" ]] && \
        cp "$tpl/.claude/settings.json" .claude/settings.json && ok "  Created .claude/settings.json"

    for rule in "$tpl/.claude/rules/"*.md; do
        [[ -f "$rule" ]] || continue
        local bn; bn=$(basename "$rule")
        [[ ! -f ".claude/rules/$bn" ]] && cp "$rule" ".claude/rules/$bn" && ok "  Created .claude/rules/$bn"
    done

    # Copy ticket templates
    if [[ -d "$tpl/.claude/ticket-templates" ]]; then
        mkdir -p .claude/ticket-templates
        for tmpl in "$tpl/.claude/ticket-templates/"*.yaml; do
            [[ -f "$tmpl" ]] || continue
            local bn; bn=$(basename "$tmpl")
            [[ ! -f ".claude/ticket-templates/$bn" ]] && \
                cp "$tmpl" ".claude/ticket-templates/$bn" && ok "  Created .claude/ticket-templates/$bn"
        done
    fi

    if [[ ! -d "vault" ]]; then
        mkdir -p vault/{raw,summaries/sources,summaries/sessions,entities,concepts,decisions}
        for vf in VAULT.md index.md log.md; do
            [[ -f "$tpl/vault/$vf" ]] && cp "$tpl/vault/$vf" "vault/$vf"
        done
        ok "  Created vault/"
    fi

    mkdir -p .mechanic/log
    ok "  Created .mechanic/log/"

    echo ""
    ok "Done! Edit CLAUDE.md, then run 'chat-force prototype'"
}

# ---------------------------------------------------------------------------
cmd_create_ticket() {
    require_project

    local template=""
    local interactive=false
    local -a fields=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --template) template="$2"; shift 2 ;;
            --field) fields+=("$2"); shift 2 ;;
            --interactive) interactive=true; shift ;;
            *) error "Unknown arg: $1"; exit 1 ;;
        esac
    done

    [[ -z "$template" ]] && { error "Missing --template <name>"; exit 1; }

    local tpl_file=".claude/ticket-templates/${template}.yaml"
    if [[ ! -f "$tpl_file" ]]; then
        error "Template '$template' not found."
        error "Available templates:"
        for f in .claude/ticket-templates/*.yaml; do
            [[ -f "$f" ]] || continue
            local n; n=$(basename "$f" .yaml)
            error "  $n"
        done
        exit 1
    fi

    # Interactive mode: launch Claude CLI to interview for fields
    if [[ "$interactive" == "true" ]]; then
        require_claude
        local session_id
        session_id=$(uuidgen 2>/dev/null || python3 -c "import uuid; print(uuid.uuid4())")

        info "Launching interactive ticket creation (template: $template)"
        local interview_prompt
        interview_prompt="You are helping create a ticket from the '${template}' template. Read the template at ${tpl_file} to see what fields are required. Interview the user for each required field one at a time. When all fields are gathered, output the complete ticket as YAML to stdout and save it to .ticket-context."

        claude --session-id "$session_id" -p "$interview_prompt"
        return $?
    fi

    # Non-interactive: validate fields are provided
    python3 -c "
import sys, yaml

tpl_path = sys.argv[1]
template_name = sys.argv[2]
field_args = sys.argv[3:]

with open(tpl_path) as f:
    tpl = yaml.safe_load(f)

# Parse --field key=value pairs
provided = {}
for fa in field_args:
    if '=' not in fa:
        print(f'Invalid field format: {fa} (expected key=value)', file=sys.stderr)
        sys.exit(1)
    k, v = fa.split('=', 1)
    provided[k] = v

# Check required inputs
required_names = [inp['name'] for inp in tpl.get('required_inputs', [])]
missing = [n for n in required_names if n not in provided]
if missing:
    print(f'Missing required fields: {', '.join(missing)}', file=sys.stderr)
    print(f'Hint: use --interactive to gather fields via interview', file=sys.stderr)
    sys.exit(1)

# Build ticket output
ticket = {
    'template': template_name,
    'inputs': provided,
    'acceptance_criteria': tpl.get('acceptance_criteria', []),
    'required_artifacts': tpl.get('required_artifacts', []),
    'skills': tpl.get('skills', []),
}
print(yaml.dump(ticket, default_flow_style=False, sort_keys=False))
" "$tpl_file" "$template" ${fields[@]+"${fields[@]}"}
}

# ---------------------------------------------------------------------------
cmd_list_templates() {
    require_project

    local tpl_dir=".claude/ticket-templates"
    [[ -d "$tpl_dir" ]] || { error "No ticket templates found. Run 'chat-force init' first."; exit 1; }

    info "Available ticket templates:"
    echo ""
    for f in "$tpl_dir"/*.yaml; do
        [[ -f "$f" ]] || continue
        local name desc
        name=$(basename "$f" .yaml)
        desc=$(python3 -c "
import yaml, sys
with open(sys.argv[1]) as f:
    d = yaml.safe_load(f)
print(d.get('description', '(no description)'))
" "$f")
        printf "  %-20s %s\n" "$name" "$desc"
    done
}

# ---------------------------------------------------------------------------
cmd_run() {
    require_claude
    require_project

    local ticket_id=""
    local branch_override=""
    local -a extra_args=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --branch) branch_override="$2"; shift 2 ;;
            -*) extra_args+=("$1"); shift ;;
            *)
                if [[ -z "$ticket_id" ]]; then
                    ticket_id="$1"; shift
                else
                    extra_args+=("$1"); shift
                fi
                ;;
        esac
    done

    [[ -z "$ticket_id" ]] && { error "Usage: chat-force run <ticket-id> [--branch name]"; exit 1; }

    # Determine branch name
    local branch
    if [[ -n "$branch_override" ]]; then
        branch="$branch_override"
    else
        branch="ticket/${ticket_id}"
    fi

    # Checkout or create branch
    if git rev-parse --verify "$branch" &>/dev/null; then
        info "Checking out existing branch: $branch"
        git checkout "$branch"
    else
        info "Creating new branch: $branch"
        git checkout -b "$branch"
    fi

    # --- Write ticket context file ---
    # This file is read by the swarm, PM, and mechanic sessions
    _write_ticket_context "$ticket_id" "$branch"

    # === PHASE 1: Execution Swarm ===
    _run_swarm "$ticket_id" "$branch" ${extra_args[@]+"${extra_args[@]}"}

    # === PHASE 2: PM Verification ===
    _run_pm_verification "$ticket_id" "$branch"

    # === PHASE 3: Mechanic Reflection ===
    _run_mechanic_reflection "$ticket_id" "$branch"

    # --- Cleanup ---
    rm -f .ticket-context

    info "All phases complete for $ticket_id on branch $branch"
}

# ---------------------------------------------------------------------------
_write_ticket_context() {
    local ticket_id="$1"
    local branch="$2"
    local attempt=1

    # Count previous attempts from git log
    if git log --oneline --grep="WIP: ${ticket_id}" 2>/dev/null | grep -q .; then
        attempt=$(( $(git log --oneline --grep="WIP: ${ticket_id}" | wc -l) + 1 ))
    fi

    python3 -c "
import yaml, sys
ctx = {
    'ticket_id': sys.argv[1],
    'branch': sys.argv[2],
    'attempt': int(sys.argv[3]),
}
# Try to read acceptance criteria from ticket template if linked
import glob
for tpl_file in glob.glob('.claude/ticket-templates/*.yaml'):
    with open(tpl_file) as f:
        tpl = yaml.safe_load(f)
    # Use general template as fallback context
    if tpl.get('name') == 'general':
        ctx['acceptance_criteria'] = tpl.get('acceptance_criteria', [])
        ctx['required_artifacts'] = tpl.get('required_artifacts', [])
        break
print(yaml.dump(ctx, default_flow_style=False, sort_keys=False))
" "$ticket_id" "$branch" "$attempt" > .ticket-context
}

# ---------------------------------------------------------------------------
_run_swarm() {
    local ticket_id="$1"
    local branch="$2"
    shift 2

    local session_id
    session_id=$(uuidgen 2>/dev/null || python3 -c "import uuid; print(uuid.uuid4())")

    info "=== Phase 1: Execution Swarm ==="
    info "Ticket: $ticket_id | Branch: $branch | Session: $session_id"
    echo ""

    # Build the swarm prompt with ticket context
    local swarm_prompt
    swarm_prompt="You are executing ticket ${ticket_id}. Read .ticket-context for the full ticket details including acceptance criteria. IMPORTANT: Before starting work, read the ticket's comment history in Linear (use list_comments for ${ticket_id}) to check for previous attempts. If prior attempts exist, read the PM Review comments to understand what failed and why — do NOT repeat the same mistakes. Work to satisfy all acceptance criteria. When done, ensure all artifacts are saved and committed."

    local exit_code=0
    claude --session-id "$session_id" -p "$swarm_prompt" "$@" || exit_code=$?

    echo ""
    [[ $exit_code -ne 0 ]] && [[ $exit_code -ne 130 ]] && warn "Swarm exited with code $exit_code"

    # Commit any work from the swarm
    if [[ -n "$(git status --porcelain)" ]]; then
        git add -A
        git commit -m "WIP: ${ticket_id} session"
        local commit_hash
        commit_hash=$(git rev-parse --short HEAD)
        ok "Swarm committed: $commit_hash"
    else
        info "Swarm produced no changes."
    fi
}

# ---------------------------------------------------------------------------
_run_pm_verification() {
    local ticket_id="$1"
    local branch="$2"

    local session_id
    session_id=$(uuidgen 2>/dev/null || python3 -c "import uuid; print(uuid.uuid4())")

    echo ""
    info "=== Phase 2: PM Verification ==="
    info "Ticket: $ticket_id | Session: $session_id"
    echo ""

    local pm_args=()
    if [[ -f "$PM_PROMPT" ]]; then
        pm_args+=(--system-prompt "$PM_PROMPT")
    fi

    local pm_instruction="Verify the deliverables for ticket ${ticket_id}. Read .ticket-context for acceptance criteria, then inspect the artifacts produced. Present your pass/fail verdict per criterion."

    local exit_code=0
    claude --session-id "$session_id" "${pm_args[@]}" -p "$pm_instruction" || exit_code=$?

    echo ""
    [[ $exit_code -ne 0 ]] && [[ $exit_code -ne 130 ]] && warn "PM verification exited with code $exit_code"

    ok "PM verification complete."
}

# ---------------------------------------------------------------------------
_run_mechanic_reflection() {
    local ticket_id="$1"
    local branch="$2"

    local session_id
    session_id=$(uuidgen 2>/dev/null || python3 -c "import uuid; print(uuid.uuid4())")

    echo ""
    info "=== Phase 3: Mechanic Reflection ==="
    info "Ticket: $ticket_id | Session: $session_id"
    echo ""

    local mechanic_args=()
    if [[ -f "$MECHANIC_PROMPT" ]]; then
        mechanic_args+=(--system-prompt "$MECHANIC_PROMPT")
    fi

    local mechanic_instruction="Analyze the execution of ticket ${ticket_id} on branch ${branch}. Read .ticket-context for the ticket details. Review git diff and session artifacts, then propose harness improvements."

    local exit_code=0
    claude --session-id "$session_id" "${mechanic_args[@]}" -p "$mechanic_instruction" || exit_code=$?

    echo ""
    [[ $exit_code -ne 0 ]] && [[ $exit_code -ne 130 ]] && warn "Mechanic exited with code $exit_code"

    # Commit any mechanic changes
    if [[ -n "$(git status --porcelain)" ]]; then
        git add -A
        git commit -m "mechanic: ${ticket_id} harness improvements"
        local commit_hash
        commit_hash=$(git rev-parse --short HEAD)
        ok "Mechanic committed: $commit_hash"
    else
        info "Mechanic produced no changes."
    fi
}

# ---------------------------------------------------------------------------
cmd_status() {
    require_project

    local branch
    branch=$(git branch --show-current 2>/dev/null || echo "(detached)")

    local ticket_id=""
    local attempts=0

    # Extract ticket ID from branch name
    if [[ "$branch" == ticket/* ]]; then
        ticket_id="${branch#ticket/}"
        attempts=$(git log --oneline --grep="WIP: ${ticket_id}" 2>/dev/null | wc -l | tr -d ' ')
    fi

    echo ""
    info "Project Status"
    echo "  Branch:     $branch"

    if [[ -n "$ticket_id" ]]; then
        echo "  Ticket:     $ticket_id"
        echo "  Attempts:   $attempts"

        # Show ticket context if it exists
        if [[ -f ".ticket-context" ]]; then
            echo "  Context:    .ticket-context (active session)"
        fi
    else
        echo "  Ticket:     (none — not on a ticket branch)"
    fi

    # Show uncommitted changes
    local changes
    changes=$(git status --porcelain 2>/dev/null | wc -l | tr -d ' ')
    echo "  Changes:    $changes uncommitted file(s)"
    echo ""
}

# ---------------------------------------------------------------------------
cmd_help() {
    cat <<EOF
chat-force v${CHAT_FORCE_VERSION} — self-improving prototyping tool

Usage:
  chat-force prototype [args]           Prototype session → mechanic handoff
  chat-force mechanic [args]            Mechanic review of current project
  chat-force run <ticket-id> [--branch] Execute ticket (swarm → PM → mechanic)
  chat-force create-ticket --template T Create ticket (--field or --interactive)
  chat-force list-templates             List available ticket templates
  chat-force status                     Show current ticket, branch, attempts
  chat-force init [--template T]        Scaffold a new project
  chat-force help                       This help

Project structure:
  CLAUDE.md                    Identity and instructions
  vault/                       Knowledge base
  .claude/rules/               Rules (brand, eval, never-list)
  .claude/skills/              Skills (grown by mechanic)
  .claude/agents/              Sub-agents (grown by mechanic)
  .claude/ticket-templates/    Ticket templates (YAML)
  .mechanic/log/               Proposal history
EOF
}

# ---------------------------------------------------------------------------
case "${1:-help}" in
    prototype)      shift; cmd_prototype "$@" ;;
    mechanic)       shift; cmd_mechanic "$@" ;;
    run)            shift; cmd_run "$@" ;;
    create-ticket)  shift; cmd_create_ticket "$@" ;;
    list-templates) shift; cmd_list_templates "$@" ;;
    status)         shift; cmd_status "$@" ;;
    init)           shift; cmd_init "$@" ;;
    help|--help|-h) cmd_help ;;
    version|--version|-v) echo "chat-force v${CHAT_FORCE_VERSION}" ;;
    *) error "Unknown command: $1"; cmd_help; exit 1 ;;
esac
